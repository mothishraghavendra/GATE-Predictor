# Secret key for Flask application (REQUIRED in production)
# Generate a secure key using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Flask environment (development/production/testing)
FLASK_ENV=development

# Debug mode (True/False)
FLASK_DEBUG=True

# Application host
FLASK_HOST=0.0.0.0

# Application port
FLASK_PORT=5000
